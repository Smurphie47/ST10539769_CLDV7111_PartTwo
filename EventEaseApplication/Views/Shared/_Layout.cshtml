<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - EventEase</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>
    <header class="top-navbar">
        <div class="brand">
            <i class="bi bi-calendar-event"></i>
            <span>EventEase</span>
        </div>

        <nav class="top-links">
            <a asp-controller="Home" asp-action="Index">Dashboard</a>
            <a asp-controller="Venues" asp-action="Index">Venues</a>
            <a asp-controller="Events" asp-action="Index">Events</a>
            <a asp-controller="Bookings" asp-action="Index">Bookings</a>
        </nav>
    </header>

    <div class="app-shell">
        <aside class="sidebar">
            <nav>
                <a asp-controller="Home" asp-action="Index">
                    <i class="bi bi-speedometer2"></i>
                    Dashboard
                </a>

                <a asp-controller="Venues" asp-action="Index">
                    <i class="bi bi-building"></i>
                    Venues
                </a>

                <a asp-controller="Events" asp-action="Index">
                    <i class="bi bi-calendar3"></i>
                    Events
                </a>

                <a asp-controller="Bookings" asp-action="Index">
                    <i class="bi bi-card-checklist"></i>
                    Bookings
                </a>

                <hr />

                <a asp-controller="Venues" asp-action="Create">
                    <i class="bi bi-plus-circle"></i>
                    Add Venue
                </a>

                <a asp-controller="Events" asp-action="Create">
                    <i class="bi bi-plus-circle"></i>
                    Add Event
                </a>

                <a asp-controller="Bookings" asp-action="Create">
                    <i class="bi bi-plus-circle"></i>
                    New Booking
                </a>
            </nav>
        </aside>

        <main class="main-content">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>