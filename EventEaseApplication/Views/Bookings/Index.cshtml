@model IEnumerable<EventEaseApplication.Models.Booking>
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Bookings";
}

<h1>Bookings</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Booking</a>
</p>

@if (ViewData["AvailabilityMessage"] != null)
{
    <div class="alert @ViewData["AvailabilityClass"]">
        @ViewData["AvailabilityMessage"]
    </div>
}

<form asp-action="Index" method="get" class="mb-4">
    <div class="card">
        <div class="card-header">
            <strong>Search, Filter, and Check Venue Availability</strong>
        </div>

        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Search</label>
                    <input type="text"
                           name="searchString"
                           value="@ViewData["CurrentFilter"]"
                           class="form-control"
                           placeholder="Booking ID, event, venue, or date..." />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Venue</label>
                    <select name="venueId"
                            class="form-control"
                            asp-items="@(ViewData["VenueId"] as SelectList)">
                        <option value="">All Venues</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Start Date</label>
                    <input type="date"
                           name="startDate"
                           value="@ViewData["StartDate"]"
                           class="form-control" />
                </div>

                <div class="col-md-2">
                    <label class="form-label">End Date</label>
                    <input type="date"
                           name="endDate"
                           value="@ViewData["EndDate"]"
                           class="form-control" />
                </div>

                <div class="col-md-2">
                    <label class="form-label">Availability Date</label>
                    <input type="date"
                           name="availabilityDate"
                           value="@ViewData["AvailabilityDate"]"
                           class="form-control" />
                </div>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-outline-primary">Apply</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
            </div>

            <small class="text-muted d-block mt-2">
                To check venue availability, select a venue and choose an availability date.
            </small>
        </div>
    </div>
</form>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Booking ID</th>
            <th>Event</th>
            <th>Venue</th>
            <th>Booking Date</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.BookingId</td>
                <td>@item.Event?.EventName</td>
                <td>@item.Venue?.VenueName</td>
                <td>@item.BookingDate.ToString("yyyy-MM-dd")</td>

                <td>
                    <a asp-action="Edit" asp-route-id="@item.BookingId">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.BookingId">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.BookingId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>