@model IEnumerable<EventEaseApplication.Models.Event>
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Events";
}

<h1>Events</h1>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Event</a>
</p>

<form asp-action="Index" method="get" class="mb-4">
    <div class="card">
        <div class="card-header">
            <strong>Search and Filter Events</strong>
        </div>

        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Search</label>
                    <input type="text"
                           name="searchString"
                           value="@ViewData["CurrentFilter"]"
                           class="form-control"
                           placeholder="Search event, venue, type, or description..." />
                </div>

                <div class="col-md-2">
                    <label class="form-label">Event Type</label>
                    <select name="eventTypeId"
                            class="form-control"
                            asp-items="@(ViewData["EventTypeId"] as SelectList)">
                        <option value="">All Types</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Venue</label>
                    <select name="venueId"
                            class="form-control"
                            asp-items="@(ViewData["VenueId"] as SelectList)">
                        <option value="">All Venues</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Start Date</label>
                    <input type="date"
                           name="startDate"
                           value="@ViewData["StartDate"]"
                           class="form-control" />
                </div>

                <div class="col-md-2">
                    <label class="form-label">End Date</label>
                    <input type="date"
                           name="endDate"
                           value="@ViewData["EndDate"]"
                           class="form-control" />
                </div>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-outline-primary">Apply Filters</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
            </div>
        </div>
    </div>
</form>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Image</th>
            <th>Event Name</th>
            <th>Event Type</th>
            <th>Date</th>
            <th>Venue</th>
            <th>Description</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    <img src="@item.ImageUrl"
                         alt="@item.EventName"
                         style="width:120px;height:80px;object-fit:cover;border-radius:4px;" />
                </td>

                <td>@item.EventName</td>
                <td>@item.EventType?.Name</td>
                <td>@item.EventDate.ToString("yyyy-MM-dd")</td>
                <td>@item.Venue?.VenueName</td>
                <td>@item.Description</td>

                <td>
                    <a asp-action="Edit" asp-route-id="@item.EventId">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.EventId">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.EventId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>