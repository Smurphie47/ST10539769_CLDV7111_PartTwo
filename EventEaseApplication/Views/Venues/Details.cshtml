@model EventEaseApplication.Models.Venue

@{
    ViewData["Title"] = "Venue Details";
}

<h1>Venue Details</h1>

<div>
    <hr />

    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <div class="mb-3">
            <img src="@Model.ImageUrl" alt="@Model.VenueName" style="width:300px;height:180px;object-fit:cover;" />
        </div>
    }

    <dl class="row">
        <dt class="col-sm-2">
            Venue Name
        </dt>
        <dd class="col-sm-10">
            @Model.VenueName
        </dd>

        <dt class="col-sm-2">
            Location
        </dt>
        <dd class="col-sm-10">
            @Model.Location
        </dd>

        <dt class="col-sm-2">
            Capacity
        </dt>
        <dd class="col-sm-10">
            @Model.Capacity
        </dd>

        <dt class="col-sm-2">
            Image URL
        </dt>
        <dd class="col-sm-10">
            @Model.ImageUrl
        </dd>
    </dl>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model.VenueId" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>